#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# fars — Open-FARS project scaffolding CLI
# ============================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="$(cd "$SCRIPT_DIR/../template" && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    cat <<'EOF'
Usage: fars <command> [options]

Commands:
  init [TARGET_DIR]    Scaffold a new Open-FARS research project
  install              Symlink fars to /usr/local/bin for global access

Examples:
  fars init                    # Initialize in current directory
  fars init ~/research/my-proj # Initialize in specified directory
  fars install                 # Make fars available globally
EOF
}

cmd_install() {
    local link="/usr/local/bin/fars"
    local target="$SCRIPT_DIR/fars"

    if [ -L "$link" ]; then
        echo -e "${YELLOW}Symlink already exists: $link -> $(readlink "$link")${NC}"
        echo -e "Updating to: $target"
        ln -sf "$target" "$link"
    else
        ln -sf "$target" "$link"
    fi
    echo -e "${GREEN}Installed: fars -> $target${NC}"
    echo "You can now run 'fars' from anywhere."
}

cmd_init() {
    local target_dir="${1:-.}"
    target_dir="$(cd "$target_dir" 2>/dev/null && pwd || mkdir -p "$target_dir" && cd "$target_dir" && pwd)"

    echo -e "${BOLD}${CYAN}"
    echo "  ___  ___  ___ _ __         __  __ _ _ __ ___"
    echo " / _ \\/ _ \\/ _ \\ '_ \\ _____ / _|/ _\` | '__/ __|"
    echo "| (_) |  _/  __/ | | |_____| | | (_| | |  \\__ \\"
    echo " \\___/| |  \\___|_| |_|     |_|  \\__,_|_|  |___/"
    echo ""
    echo -e "${NC}"
    echo -e "${BOLD}Open-FARS Project Scaffolding${NC}"
    echo -e "Target directory: ${CYAN}$target_dir${NC}"
    echo ""

    # Guard: check if already initialized
    if [ -d "$target_dir/.open-fars" ]; then
        echo -e "${RED}Error: $target_dir/.open-fars already exists.${NC}"
        echo "This directory appears to already be an Open-FARS project."
        echo "If you want to re-initialize, remove .open-fars/ first."
        exit 1
    fi

    # --- Interactive prompts ---
    echo -e "${BOLD}--- Project Configuration ---${NC}"
    echo ""

    # Direction slug
    while true; do
        read -rp "$(echo -e "${CYAN}Research direction slug${NC} (e.g. llm-alignment): ")" direction
        if [[ -n "$direction" && "$direction" =~ ^[a-z0-9][a-z0-9-]*[a-z0-9]$ ]]; then
            break
        fi
        echo -e "${RED}Invalid slug. Use lowercase letters, numbers, and hyphens (e.g. llm-alignment).${NC}"
    done

    # Description
    read -rp "$(echo -e "${CYAN}One-line description${NC}: ")" description
    if [ -z "$description" ]; then
        description="Research on $direction"
    fi

    # Target venue
    read -rp "$(echo -e "${CYAN}Target venue${NC} (e.g. NeurIPS 2026): ")" venue
    if [ -z "$venue" ]; then
        venue="TBD"
    fi

    # Language
    while true; do
        read -rp "$(echo -e "${CYAN}Paper language${NC} [en/zh] (default: en): ")" language
        language="${language:-en}"
        if [[ "$language" == "en" || "$language" == "zh" ]]; then
            break
        fi
        echo -e "${RED}Please enter 'en' or 'zh'.${NC}"
    done

    # Seed queries
    echo -e "${CYAN}Seed queries${NC} (comma-separated search terms or paper titles):"
    read -rp "> " seed_queries_raw
    if [ -z "$seed_queries_raw" ]; then
        seed_queries_raw="$direction"
    fi

    # Compute description
    read -rp "$(echo -e "${CYAN}Compute resources${NC} (e.g. 4x NVIDIA A100, leave empty to skip): ")" compute
    compute="${compute:-}"

    # Email (optional)
    read -rp "$(echo -e "${CYAN}Notification email${NC} (optional, for email-notify skill): ")" email

    echo ""
    echo -e "${BOLD}--- Summary ---${NC}"
    echo -e "  Direction:    ${GREEN}$direction${NC}"
    echo -e "  Description:  ${GREEN}$description${NC}"
    echo -e "  Venue:        ${GREEN}$venue${NC}"
    echo -e "  Language:     ${GREEN}$language${NC}"
    echo -e "  Seed queries: ${GREEN}$seed_queries_raw${NC}"
    echo -e "  Compute:      ${GREEN}${compute:-N/A}${NC}"
    echo -e "  Email:        ${GREEN}${email:-N/A}${NC}"
    echo ""

    read -rp "Proceed? [Y/n] " confirm
    confirm="${confirm:-Y}"
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 0
    fi

    echo ""
    echo -e "${BOLD}Scaffolding project...${NC}"

    # --- Copy template files ---
    # Use rsync to copy, preserving structure. Fallback to cp -r.
    if command -v rsync &>/dev/null; then
        rsync -a "$TEMPLATE_DIR/" "$target_dir/"
    else
        cp -r "$TEMPLATE_DIR/." "$target_dir/"
    fi

    echo -e "  ${GREEN}+${NC} Template files copied"

    # --- Build seed queries YAML ---
    local seed_queries_yaml=""
    IFS=',' read -ra queries <<< "$seed_queries_raw"
    for q in "${queries[@]}"; do
        q="$(echo "$q" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        if [ -n "$q" ]; then
            seed_queries_yaml="${seed_queries_yaml}    - \"${q}\"
"
        fi
    done

    # Generate timestamp
    local timestamp
    timestamp="$(TZ=Asia/Shanghai date +"%Y-%m-%dT%H:%M+08:00")"

    # --- Generate config.yaml from template ---
    # Source: template/.open-fars/config.yaml.example (single source of truth)
    local config_src="$TEMPLATE_DIR/.open-fars/config.yaml.example"
    local config_file="$target_dir/.open-fars/config.yaml"

    sed \
        -e "s|{{DIRECTION}}|${direction}|g" \
        -e "s|{{DESCRIPTION}}|${description}|g" \
        -e "s|{{VENUE}}|${venue}|g" \
        -e "s|{{LANGUAGE}}|${language}|g" \
        -e "s|{{COMPUTE}}|${compute}|g" \
        "$config_src" > "$config_file"

    # Replace {{SEED_QUERIES}} placeholder with multiline YAML list
    # Use a temp file because sed can't reliably insert multiline content
    local tmpfile
    tmpfile="$(mktemp)"
    while IFS= read -r line; do
        if [[ "$line" == *'{{SEED_QUERIES}}'* ]]; then
            printf '%s' "$seed_queries_yaml"
        else
            printf '%s\n' "$line"
        fi
    done < "$config_file" > "$tmpfile"
    mv "$tmpfile" "$config_file"

    echo -e "  ${GREEN}+${NC} config.yaml generated"

    # --- Generate registry.yaml from template ---
    # Source: template/.open-fars/meta/registry.yaml.template (single source of truth)
    local registry_src="$TEMPLATE_DIR/.open-fars/meta/registry.yaml.template"
    local registry_file="$target_dir/.open-fars/meta/registry.yaml"

    sed \
        -e "s|{{DIRECTION}}|${direction}|g" \
        -e "s|{{DESCRIPTION}}|${description}|g" \
        -e "s|{{TIMESTAMP}}|${timestamp}|g" \
        "$registry_src" > "$registry_file"

    echo -e "  ${GREEN}+${NC} registry.yaml generated"

    # --- Generate email config.json if email provided ---
    if [ -n "$email" ]; then
        local email_src="$TEMPLATE_DIR/.claude/skills/email-notify/config.json.example"
        local email_config="$target_dir/.claude/skills/email-notify/config.json"

        sed \
            -e "s|your-email@qq.com|${email}|g" \
            "$email_src" > "$email_config"

        echo -e "  ${GREEN}+${NC} email-notify config.json generated (update smtp_auth_code!)"
    fi

    # --- Git init ---
    cd "$target_dir"
    if [ ! -d ".git" ]; then
        git init -q
        git config user.name hzt
        git config user.email 3061613175@qq.com
        git add -A
        git commit -q -m "init: scaffold Open-FARS project for $direction"
        echo -e "  ${GREEN}+${NC} Git repository initialized with initial commit"
    else
        echo -e "  ${YELLOW}!${NC} Git repository already exists, skipping git init"
    fi

    echo ""
    echo -e "${GREEN}${BOLD}Done!${NC} Project scaffolded at: ${CYAN}$target_dir${NC}"
    echo ""
    echo -e "${BOLD}Next steps:${NC}"
    echo -e "  1. cd $target_dir"
    echo -e "  2. Review .open-fars/config.yaml and adjust as needed"
    if [ -n "$email" ]; then
        echo -e "  3. Update SMTP auth code in .claude/skills/email-notify/config.json"
        echo -e "  4. Open Claude Code and start the pipeline: \"Start the Open-FARS pipeline\""
    else
        echo -e "  3. Open Claude Code and start the pipeline: \"Start the Open-FARS pipeline\""
    fi
    echo ""
}

# --- Main dispatch ---
case "${1:-}" in
    init)
        shift
        cmd_init "${1:-}"
        ;;
    install)
        cmd_install
        ;;
    -h|--help|help)
        usage
        ;;
    "")
        usage
        exit 1
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        usage
        exit 1
        ;;
esac
